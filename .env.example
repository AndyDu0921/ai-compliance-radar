# ── App ──────────────────────────────────────────────────
APP_NAME=Compliance Radar
APP_ENV=development

# ── Storage ──────────────────────────────────────────────
DATABASE_PATH=storage/app.db
MAX_UPLOAD_MB=10

# ── Auth ─────────────────────────────────────────────────
# If set, all /api/* endpoints require header: X-API-Key: <value>
# Leave blank to disable auth during local development
ADMIN_API_KEY=

# ── LLM (optional) ───────────────────────────────────────
# Fill these in to enable AI-enhanced analysis
# Compatible with any OpenAI-format provider (Claude, OpenAI, DeepSeek, etc.)
DEFAULT_USE_LLM=false
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_SECONDS=60
