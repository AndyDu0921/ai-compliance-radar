APP_NAME=Compliance Radar
APP_VERSION=0.3.0
APP_DEPLOYED_AT=
MAX_UPLOAD_MB=10
DEFAULT_USE_LLM=false
STORE_RAW_INPUT=false
JOB_RETENTION_DAYS=7

# If set, /api/v1/jobs* endpoints require header: X-API-Key: <value>
ADMIN_API_KEY=

# Optional Cloudflare Turnstile settings for public scan protection
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional OpenAI-compatible LLM settings
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT_SECONDS=60
